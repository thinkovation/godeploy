{
  "user": "your-username",
  "host": "your-server.com",
  "port": "22",
  "key": "/path/to/your/private/key",
  "path": "/home/user/app",
  "service": "your-app.service",
  "output": "myapp",
  "entry": "main.go",
  "commands": [
    "chmod +x /home/user/app/myapp",
    "echo 'Deployment complete'"
  ],
  "files": [
    {
      "src": "config.yaml",
      "dst": "/home/user/app/config.yaml",
      "is_dir": false,
      "executable": false
    },
    {
      "src": "assets",
      "dst": "/home/user/app/assets",
      "is_dir": true,
      "executable": false
    },
    {
      "src": "scripts/setup.sh",
      "dst": "/home/user/app/setup.sh",
      "is_dir": false,
      "executable": true
    }
  ]
}