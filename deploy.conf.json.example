{
  "user": "ubuntu",
  "host": "example.com",
  "port": "22",
  "key": "~/.ssh/id_rsa",
  "path": "/home/ubuntu/app",
  "service": "myapp",
  "output": "myapp",
  "entry": "main.go",
  "commands": [
    "deploy",
    "copyfiles",
    "echo 'Deployment complete!'"
  ],
  "files": [
    {
      "src": "assets",
      "dst": "/home/ubuntu/app/assets",
      "is_dir": true,
      "executable": false
    },
    {
      "src": "config.yaml",
      "dst": "/home/ubuntu/app/config.yaml",
      "is_dir": false,
      "executable": false
    },
    {
      "src": "scripts/start.sh",
      "dst": "/home/ubuntu/app/start.sh",
      "is_dir": false,
      "executable": true
    }
  ]
}